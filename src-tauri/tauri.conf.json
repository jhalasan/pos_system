{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nexa POS Cashier",
  "version": "0.1.1",
  "identifier": "com.nexapos.cashier",
  "build": {
    "beforeDevCommand": "npm run dev:cashier",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:cashier",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self' customprotocol: asset:; connect-src 'self' ipc: http://ipc.localhost http://localhost:8090 http://127.0.0.1:8090 https: wss:; img-src 'self' asset: http://asset.localhost data: blob: https:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'"
    },
    "windows": [
      {
        "label": "main",
        "title": "Nexa POS Cashier",
        "visible": false,
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "center": true,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "splashscreen",
        "title": "NEXA POS",
        "url": "splash.html",
        "width": 460,
        "height": 300,
        "center": true,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "category": "Business",
    "shortDescription": "Offline-first cashier terminal",
    "longDescription": "Nexa POS cashier terminal with local product storage and background cloud synchronization.",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE5MzZGQUExQ0NCNTI3RUQKUldUdEo3WE1vZm8yR1g0OGsvaTNqeHJHaHpZbjVOUG1YUGdWeEIydGdVTXdDYTFTUERRaDN1cDMK",
      "endpoints": [
        "https://github.com/jhalasan/pos_system/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
