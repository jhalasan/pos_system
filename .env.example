API_PORT=3001
CLIENT_ORIGIN=http://localhost:5133,http://localhost:5173,http://localhost:5174,https://your-public-app-url.example.com

# This project is currently configured for PocketHost.io-hosted PocketBase.
# Replace the placeholder with your PocketHost instance URL.
POCKETBASE_URL=https://your-instance.pockethost.io
POCKETBASE_PROXY_TARGET=https://your-instance.pockethost.io

# Optional PocketBase environment selection.
# Leave POCKETBASE_URL unset only if you want to auto-select from POCKETBASE_PHASE.
# Production defaults to the live placeholder; all other NODE_ENV values default to local.
# POCKETBASE_PHASE=production
# POCKETBASE_PHASE=remoteTeamTesting
# POCKETBASE_PHASE=localAloneDevelopment

# Direct override. Uncomment when you need an exact endpoint regardless of phase.
# 1. PRODUCTION / DEPLOYMENT:
# POCKETBASE_URL=https://your-instance.pockethost.io

# 2. REMOTE TEAM TESTING:
# WARNING: ngrok URLs change every time ngrok restarts unless you use a reserved domain.
# POCKETBASE_URL=https://xxxx.ngrok-free.app

# 3. LOCAL ALONE DEVELOPMENT:
# POCKETBASE_URL=http://127.0.0.1:8090
# POCKETBASE_PROXY_TARGET=http://127.0.0.1:8090
DEFAULT_CASHIER_PASSWORD=cashier123

# Required for server-side writes that need PocketBase superuser privileges.
# Any PocketBase superuser account can be used here.
POCKETBASE_SUPERUSER_EMAIL=
POCKETBASE_SUPERUSER_PASSWORD=

# Legacy names are still supported, but the superuser names above are preferred.
# POCKETBASE_ADMIN_EMAIL=
# POCKETBASE_ADMIN_PASSWORD=

# Leave blank when Express serves the built frontend; the app will call /api on the same host.
VITE_API_URL=

# Remote teammates only need this if they run Vite locally instead of opening your ngrok app URL.
# VITE_API_URL=https://your-public-app-url.example.com/api
# PocketBase REST calls can then use:
# https://your-public-app-url.example.com/api/pocketbase/collections/...
