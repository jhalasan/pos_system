{
  "name": "pos_system",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "api": "node server/index.js",
    "start": "node server/index.js",
    "host": "npm run build && node server/index.js",
    "deploy": "npm run build && npm start",
    "dev": "vite",
    "dev:lan": "vite --host 0.0.0.0",
    "dev:cashier": "vite --mode cashier",
    "dev:cashier:lan": "vite --mode cashier --host 0.0.0.0",
    "build": "vite build",
    "build:vercel": "vite build --mode admin-web",
    "build:cashier": "vite build --mode cashier",
    "lint": "eslint .",
    "pb:rules": "node scripts/configure-pocketbase-rules.mjs",
    "pb:seed:sample": "node scripts/seed-sample-data.mjs",
    "pb:import:legacy:dry-run": "node scripts/import-legacy-json.mjs",
    "pb:import:legacy": "node scripts/import-legacy-json.mjs --apply",
    "pb:remove:sample": "node scripts/remove-sample-data.mjs",
    "pb:reset:legacy-catalog": "node scripts/reset-to-legacy-catalog.mjs --apply",
    "pb:migrate": "node scripts/backfill-base-quantity.mjs",
    "test:e2e": "node tests/e2e/run-e2e.mjs",
    "test:offline": "node --test tests/cashier-activity-log-sync.test.js tests/offline-product-catalog.test.js tests/offline-restart-persistence.test.js tests/offline-two-terminal-sync.test.js tests/out-of-stock-sale.test.js tests/product-delete-sync.test.js tests/return-disposition.test.js tests/stock-availability.test.js tests/stock-conversion.test.js tests/transaction-log-sort.test.js",
    "test:vercel": "node --test tests/admin-vercel-boundary.test.js",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "node scripts/tauri-build.mjs"
  },
  "dependencies": {
    "@tauri-apps/plugin-updater": "^2.10.1",
    "cors": "^2.8.6",
    "dexie": "^4.4.3",
    "docx": "^8.4.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "http-proxy-middleware": "^4.2.0",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "pocketbase": "^0.27.0",
    "react": "^19.2.6",
    "react-bootstrap-icons": "^1.11.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}
